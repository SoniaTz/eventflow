# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
# For local development, use your local PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/eventflow
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eventflow"

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Uploads directory
UPLOAD_DIR=./uploads
